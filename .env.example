# AgencyOS v2 Solo — copy to .env.local
# PRD v2.0 Section 8

# Auth — team auth (NextAuth v4, DB-backed users)
# Add these to .env.local. Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here-change-this
NEXTAUTH_URL=http://localhost:3000

# Neon Database (Drizzle)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL_DIRECT=  # optional, for migrations

# ImageKit (Phase 3 — File Manager)
# IMAGEKIT_PUBLIC_KEY=
# IMAGEKIT_PRIVATE_KEY=
# IMAGEKIT_URL_ENDPOINT=

# App (set in production so metadata, OG URLs, and PWA resolve correctly — avoids broken styling on some hosts)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# NEXT_PUBLIC_APP_NAME=AgencyOS

# Mostaql scrape (optional): paste your browser Cookie header for mostaql.com while logged in
# so /api/scrape-mostaql can read your bid amount when it is hidden on the public page.
# MOSTAQL_COOKIE=

# AI Chat (admin-only) — OpenRouter: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Task due reminders (cron). Generate: openssl rand -hex 32
# Set in Vercel env; Vercel Cron calls /api/cron/task-due-reminders with Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=
