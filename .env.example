# AgencyOS v2 Solo — copy to .env.local
# PRD v2.0 Section 8

# Auth — single admin (NextAuth v5)
# Generate secret: npx auth secret  (or use openssl rand -base64 32)
AUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# Single admin account — use one of:
#   ADMIN_PASSWORD=plain password   (easy for local dev)
#   ADMIN_PASSWORD_HASH=bcrypt hash (for production; generate with node -e "console.log(require('bcryptjs').hashSync('your-password', 10))")
ADMIN_EMAIL=you@youragency.com
ADMIN_PASSWORD=yourpassword
# ADMIN_PASSWORD_HASH=$2a$10$...

# Neon Database (Drizzle)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DATABASE_URL_DIRECT=  # optional, for migrations

# ImageKit (Phase 3 — File Manager)
# IMAGEKIT_PUBLIC_KEY=
# IMAGEKIT_PRIVATE_KEY=
# IMAGEKIT_URL_ENDPOINT=

# App
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_NAME=AgencyOS
